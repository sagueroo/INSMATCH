DATABASE_URL=
GROQ_API_KEY=

JWT_SECRET=
PORT=

# Origines du navigateur autorisées (CORS), séparées par des virgules — obligatoire si le front est sur un domaine
# autre que localhost (ex. https://insmatch.example.com). Même schéma + host + port que dans la barre d’adresse.
# Si Nginx sert le front et proxifie /api vers Node (même domaine), le navigateur n’envoie souvent pas de problème CORS,
# mais garde quand même l’URL du site ici pour les cas cross-origin ou les outils qui envoient Origin.
# Exemple prod (même URL que dans la barre du navigateur, sans chemin) :
# ALLOWED_ORIGINS=https://insmatch.swiloz.com,https://www.insmatch.swiloz.com
ALLOWED_ORIGINS=https://ton-domaine.fr